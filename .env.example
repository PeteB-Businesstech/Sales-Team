# ─── Reddit API (Official) ────────────────────────────────────────────────────
# Register at https://www.reddit.com/prefs/apps (script app type)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=SalesTeamBot/1.0 (by /u/your_username)

# ─── LinkedIn (manual credentials – used by browser automation) ───────────────
# Store your Sales Navigator session cookie here (see README for how to obtain)
LINKEDIN_SESSION_COOKIE=your_li_at_cookie_here

# ─── Telarus / Avox Brand Config ──────────────────────────────────────────────
BRAND_TELARUS=Telarus
BRAND_AVOX=Avox

# ─── Quota & Timing ───────────────────────────────────────────────────────────
DAILY_LEAD_QUOTA=2
# Min/max pause between browser actions (milliseconds)
ACTION_DELAY_MIN_MS=5000
ACTION_DELAY_MAX_MS=10000
# Min/max "reading" pause per post (milliseconds)
READ_PAUSE_MIN_MS=30000
READ_PAUSE_MAX_MS=120000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
